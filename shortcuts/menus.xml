    <menu name="powermenu" container="3110">
        <item name="reloadskin">
            <label>$LOCALIZE[31195]</label>
            <action>ReloadSkin()</action>
        </item>
        <item name="quit">
            <label>$LOCALIZE[13012]</label>
            <action>Quit()</action>
            <visible>System.ShowExitButton</visible>
        </item>
        <item name="mastermode">
            <label>20046</label>
            <label2>20045</label2>
            <action>mastermode</action>
            <visible>System.HasLocks</visible>
        </item>
        <item name="systemlogoff">
            <label>$LOCALIZE[31360]</label>
            <action>Dialog.Close(all,true)</action>
            <action>System.LogOff</action>
            <visible>[System.HasLoginScreen | Integer.IsGreater(System.ProfileCount,1)] + System.Loggedon</visible>
        </item>
        <item name="powerdown">
            <label>$LOCALIZE[13005]</label>
            <action>Powerdown()</action>
            <visible>System.CanPowerDown</visible>
        </item>
        <item name="cancelalarm">
            <label>$LOCALIZE[20151]</label>
            <action>CancelAlarm(shutdowntimer)</action>
            <visible>System.HasAlarm(shutdowntimer)</visible>
        </item>
        <item name="setalarm">
            <label>$LOCALIZE[20150]</label>
            <action>AlarmClock(shutdowntimer,Shutdown())</action>
            <visible>!System.HasAlarm(shutdowntimer)</visible>
            <visible>System.CanPowerDown | System.CanSuspend | System.CanHibernate</visible>
        </item>
        <item name="alarmset">
            <label>$LOCALIZE[31364]</label>
            <action>noop</action>
            <visible>System.HasAlarm(shutdowntimer)</visible>
        </item>
        <item name="suspend">
            <label>$LOCALIZE[13011]</label>
            <action>Suspend()</action>
            <visible>System.CanSuspend</visible>
        </item>
        <item name="reboot">
            <label>$LOCALIZE[13013]</label>
            <action>Reset()</action>
            <visible>System.CanReboot</visible>
        </item>
        <item name="reboottoandroid">
            <label>$LOCALIZE[31232]</label>
            <action>System.ExecWait("/usr/sbin/rebootfromnand")</action>
            <action>Reset()</action>
            <visible>System.PathExist("/dev/env")</visible>
        </item>
        <item name="skinsettings">
            <label>$LOCALIZE[31156]</label>
            <action>ActivateWindowAndFocus(skinsettings,9108,2)</action>
            <visible>System.Loggedon</visible>
        </item>
        <item name="systeminfo">
            <label>$LOCALIZE[130]</label>
            <action>ActivateWindow(systeminfo)</action>
            <visible>System.Loggedon</visible>
        </item>
        <item name="filemanager">
            <label>$LOCALIZE[10003]</label>
            <action>ActivateWindow(filemanager)</action>
            <visible>System.Loggedon</visible>
        </item>
        <item name="settings">
