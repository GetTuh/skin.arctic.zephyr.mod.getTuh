<?xml version="1.0" encoding="UTF-8"?>
<templates>

    <!-- ============================================================
         Passthrough widgets: these just include existing, unmodified
         skin-authored content blocks (Includes_Home.xml) and are not
         otherwise touched by the v2/v3 addon version.
         ============================================================ -->
    <template include="WeatherDailyInfoContent" templateonly="auto">
        <controls>
            <include>WeatherDailyItems</include>
        </controls>
    </template>

    <template include="WeatherHourlyInfoContent" templateonly="auto">
        <controls>
            <include>WeatherHourlyItems</include>
        </controls>
    </template>

    <template include="SystemInfoContent" templateonly="auto">
        <controls>
            <include>SystemInfoItems</include>
        </controls>
    </template>

    <template include="SettingsInfoContent" templateonly="auto">
        <controls>
            <include>SettingsInfoItems</include>
        </controls>
    </template>

    <!-- ============================================================
         Classic single-widget layout (used outside the modern
         multi-widget home menu layout)
         ============================================================ -->
    <template include="widget-classic">
        <property name="content" condition="widgetPath">$PROPERTY[widgetPath]</property>
        <property name="content">$VAR[DefWidgetContent]</property>
        <property name="target" condition="widgetTarget">$PROPERTY[widgetTarget]</property>
        <property name="target">$VAR[DefWidgetTarget]</property>
        <property name="aspectratio" condition="widgetAspectRatio">$PROPERTY[widgetAspectRatio]</property>
        <property name="aspectratio">keep</property>
        <property name="isgto" condition="widget=GTO">true</property>
        <property name="isgto">false</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[5000]">5000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[7000]">7000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[10000]">10000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[15000]">15000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[20000]">20000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[25000]">25000</property>
        <property name="widgetclearlogothumb" condition="widgetClearLogoThumb=no">false</property>
        <property name="widgetclearlogothumb">true</property>
        <property name="distance" condition="widgetEdgeDistance=yes">30</property>
        <property name="distance">10</property>
        <property name="widgetlisttype" condition="widgetListType">$PROPERTY[widgetListType]</property>
        <property name="widgetlisttype">list</property>
        <controls>
            <control type="$PROPERTY[widgetlisttype]" id="301">
                <skinshortcuts>visibility</skinshortcuts>
                <description>Plugin Content Widget</description>
                <left>70</left>
                <right>70</right>
                <height>297</height>
                <onup>300</onup>
                <onclick condition="isgto=true">RunPlugin(plugin://script.service.gto?action=info&amp;item=$INFO[ListItem.Property(Item)])</onclick>
                <ondown>300</ondown>
                <onback>300</onback>
                <onleft>301</onleft>
                <onright>301</onright>
                <preloaditems>2</preloaditems>
                <orientation>horizontal</orientation>
                <autoscroll time="$PROPERTY[widgetauto]">!Control.HasFocus(301) + !String.IsEmpty(Container(300).ListItem.Property(widgetAuto)) + System.IdleTime(1)</autoscroll>
                <include>ScrolltimeWidgetsList</include>
                <itemlayout width="178" height="257" condition="!String.IsEqual(Container(300).ListItem.Property(widgetaspect),Square) + ![String.IsEqual(Container(300).ListItem.Property(widgetaspect),Fanart) | String.IsEqual(Container(300).ListItem.Property(widgetaspect),Thumbnail)] + !String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.poster">
                        <param name="height" value="257"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                    </include>
                </itemlayout>
                <focusedlayout width="178" height="257" condition="!String.IsEqual(Container(300).ListItem.Property(widgetaspect),Square) + ![String.IsEqual(Container(300).ListItem.Property(widgetaspect),Fanart) | String.IsEqual(Container(300).ListItem.Property(widgetaspect),Thumbnail)] + !String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.poster.focus">
                        <param name="id" value="301"/>
                        <param name="height" value="257"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                        <param name="glow_left" value="-3"/>
                        <param name="glow_top" value="0"/>
                        <param name="glow_right" value="-2"/>
                        <param name="glow_height" value="255"/>
                    </include>
                </focusedlayout>
                <itemlayout width="254" height="257" condition="String.IsEqual(Container(300).ListItem.Property(widgetaspect),Square) | String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.square">
                        <param name="height" value="257"/>
                        <param name="aspectratio" value="$PROPERTY[aspectratio]"/>
                        <param name="distance" value="$PROPERTY[distance]"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                    </include>
                </itemlayout>
                <focusedlayout width="254" height="257" condition="String.IsEqual(Container(300).ListItem.Property(widgetaspect),Square) | String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.square.focus">
                        <param name="id" value="301"/>
                        <param name="height" value="257"/>
                        <param name="aspectratio" value="$PROPERTY[aspectratio]"/>
                        <param name="distance" value="$PROPERTY[distance]"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                        <param name="glow_height" value="253"/>
                    </include>
                </focusedlayout>
                <itemlayout width="445" height="257" condition="String.IsEqual(Container(300).ListItem.Property(widgetaspect),Fanart) + !String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.fanart">
                        <param name="height" value="257"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                    </include>
                </itemlayout>
                <focusedlayout width="445" height="257" condition="String.IsEqual(Container(300).ListItem.Property(widgetaspect),Fanart) + !String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.fanart.focus">
                        <param name="id" value="301"/>
                        <param name="height" value="257"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                        <param name="glow_left" value="6"/>
                        <param name="glow_top" value="0"/>
                        <param name="glow_right" value="7"/>
                        <param name="glow_height" value="255"/>
                    </include>
                </focusedlayout>
                <itemlayout width="445" height="257" condition="String.IsEqual(Container(300).ListItem.Property(widgetaspect),Thumbnail) + !String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.thumb">
                        <param name="height" value="257"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                        <param name="clearlogo" value="$PROPERTY[widgetclearlogothumb]"/>
                    </include>
                </itemlayout>
                <focusedlayout width="445" height="257" condition="String.IsEqual(Container(300).ListItem.Property(widgetaspect),Thumbnail) + !String.IsEqual(Container(300).ListItem.Property(widget),system)">
                    <include content="include.widget.thumb.focus">
                        <param name="id" value="301"/>
                        <param name="height" value="257"/>
                        <param name="height_reflection" value="257"/>
                        <param name="top" value="238"/>
                        <param name="reflections" value="Skin.HasSetting(home.widgets.show.reflections)"/>
                        <param name="clearlogo" value="$PROPERTY[widgetclearlogothumb]"/>
                        <param name="glow_left" value="6"/>
                        <param name="glow_top" value="0"/>
                        <param name="glow_right" value="7"/>
                        <param name="glow_height" value="255"/>
                    </include>
                </focusedlayout>
                <content limit="$VAR[DefWidgetLimit]" target="$PROPERTY[target]" sortby="$PROPERTY[widgetSortby]" sortorder="$PROPERTY[widgetSort]" browse="$VAR[DefBrowse]">$PROPERTY[content]</content>
            </control>
        </controls>
    </template>

    <!-- ============================================================
         Featured single-widget layout (background-only, no visible list)
         ============================================================ -->
    <template include="widget-featured">
        <property name="content" condition="widgetPath">$PROPERTY[widgetPath]</property>
        <property name="content">$VAR[DefWidgetContent]</property>
        <property name="target" condition="widgetTarget">$PROPERTY[widgetTarget]</property>
        <property name="target">$VAR[DefWidgetTarget]</property>
        <property name="isgto" condition="widget=GTO">true</property>
        <property name="isgto">false</property>
        <controls>
            <control type="wraplist" id="301">
                <skinshortcuts>visibility</skinshortcuts>
                <description>Widget</description>
                <width>1</width>
                <height>1</height>
                <onup>300</onup>
                <onclick condition="isgto=true">RunPlugin(plugin://script.service.gto?action=info&amp;item=$INFO[ListItem.Property(Item)])</onclick>
                <ondown>300</ondown>
                <onback>300</onback>
                <onleft>301</onleft>
                <onright>301</onright>
                <preloaditems>2</preloaditems>
                <orientation>horizontal</orientation>
                <autoscroll time="10000">!Control.HasFocus(301)</autoscroll>
                <scrolltime tween="quadratic">0</scrolltime>
                <include>Animation.FadeIn</include>
                <include>Animation.FadeOut</include>
                <itemlayout width="1" height="1"></itemlayout>
                <focusedlayout width="1" height="1"></focusedlayout>
                <content limit="$VAR[DefWidgetLimit]" target="$PROPERTY[target]" sortby="$PROPERTY[widgetSortby]" sortorder="$PROPERTY[widgetSort]" browse="$VAR[DefBrowse]">$PROPERTY[content]</content>
            </control>
        </controls>
    </template>

    <!-- ============================================================
         Modern multi-widget layout, one output per widget slot (1-6).
         Collapses v2's six near-identical widget-vertical.N templates
         into a single suffix-driven definition.

         Uses $PROPERTY (addon build-time macro, resolved to literal text
         before Kodi parses the file) throughout, never $VAR (a genuine
         Kodi *runtime* variable reference - it cannot be used as a
         boolean condition operand or inside a control's type= attribute,
         both of which Kodi resolves only at parse time).

         Container IDs are built explicitly as 301{itemindex}{slot} to
         exactly match the literal "301$PARAM[idshort]{1-6}" pattern
         hardcoded in the pre-existing, untouched Includes_Defs.xml
         "DefMultiWidgetContainer" include and Includes_Home.xml
         "widget.title.label" include - NOT via the addon's own
         idprefix/id auto-numbering, whose exact formula isn't
         documented and can't be verified against those two includes.
         ============================================================ -->
    <template>
        <output include="widget-vertical.1" />
        <output include="widget-vertical.2" suffix=".2" />
        <output include="widget-vertical.3" suffix=".3" />
        <output include="widget-vertical.4" suffix=".4" />
        <output include="widget-vertical.5" suffix=".5" />
        <output include="widget-vertical.6" suffix=".6" />

        <property name="slot" condition="!suffix">1</property>
        <property name="slot" condition="suffix=.2">2</property>
        <property name="slot" condition="suffix=.3">3</property>
        <property name="slot" condition="suffix=.4">4</property>
        <property name="slot" condition="suffix=.5">5</property>
        <property name="slot" condition="suffix=.6">6</property>

        <property name="cid">301$PROPERTY[index]$PROPERTY[slot]</property>

        <property name="ispvrlayout" condition="widget=epg">true</property>
        <property name="ispvrlayout">false</property>
        <property name="widgetlimit" condition="widget=epg">5</property>
        <property name="widgetlimit">$VAR[DefWidgetLimit]</property>
        <property name="isnormallayout" condition="widget=epg">false</property>
        <property name="isnormallayout" condition="widgetTarget=weather">false</property>
        <property name="isnormallayout" condition="widgetTarget=system">false</property>
        <property name="isnormallayout" condition="widget=mysubmenu">false</property>
        <property name="isnormallayout">true</property>
        <property name="issettingslayout" condition="widget=settings">true</property>
        <property name="issettingslayout">false</property>
        <property name="issystemlayout" condition="widgetTarget=system">true</property>
        <property name="issystemlayout">false</property>
        <property name="issubmenulayout" condition="!suffix + widget=mysubmenu">true</property>
        <property name="issubmenulayout">false</property>
        <property name="isweatherlayout" condition="widgetTarget=weather">true</property>
        <property name="isweatherlayout">false</property>
        <property name="isfullscreenwidget" condition="widgetFullscreen=yes">true</property>
        <property name="isfullscreenwidget">false</property>
        <property name="layoutheight" condition="widgetaspect=SquareMedium">175</property>
        <property name="layoutheight" condition="widgetaspect=SquareSmall">125</property>
        <property name="layoutheight" condition="widget=mysubmenu">325</property>
        <property name="layoutheight" condition="widgetFullscreen=yes">710</property>
        <property name="layoutheight">325</property>
        <property name="layoutheight2" condition="widgetaspect=SquareMedium">185</property>
        <property name="layoutheight2" condition="widgetaspect=SquareSmall">135</property>
        <property name="layoutheight2" condition="widget=mysubmenu">365</property>
        <property name="layoutheight2" condition="widgetFullscreen=yes">780</property>
        <property name="layoutheight2">365</property>
        <property name="labelisvisible" condition="widget=mysubmenu">false</property>
        <property name="labelisvisible" condition="widgetTarget=weather">false</property>
        <property name="labelisvisible" condition="widgetTarget=system">false</property>
        <property name="labelisvisible">true</property>
        <property name="content" condition="widgetPath">$PROPERTY[widgetPath]</property>
        <property name="content">$VAR[DefWidgetContent]</property>
        <property name="isgto" condition="widget=GTO">true</property>
        <property name="isgto">false</property>
        <property name="target" condition="widgetTarget">$PROPERTY[widgetTarget]</property>
        <property name="target">$VAR[DefWidgetTarget]</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[5000]">5000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[7000]">7000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[10000]">10000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[15000]">15000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[20000]">20000</property>
        <property name="widgetauto" condition="widgetAuto=$NUMBER[25000]">25000</property>
        <property name="widgetlisttype" condition="widgetListType">$PROPERTY[widgetListType]</property>
        <property name="widgetlisttype">fixedlist</property>
        <property name="widgetclearlogothumb" condition="widgetClearLogoThumb=no">false</property>
        <property name="widgetclearlogothumb">true</property>
        <property name="aspectratio" condition="widgetAspectRatio">$PROPERTY[widgetAspectRatio]</property>
        <property name="aspectratio">keep</property>
        <property name="distance" condition="widgetEdgeDistance=yes">30</property>
        <property name="distance">10</property>
        <property name="orientation" condition="widget=epg">vertical</property>
        <property name="orientation">horizontal</property>
        <property name="widgetaspectcheck" condition="widget=settings">Square</property>
        <property name="widgetaspectcheck" condition="widgetTarget=system">Square</property>
        <property name="widgetaspectcheck" condition="widgetaspect=ThumbnailPosterSmall">ThumbPoSmall</property>
        <property name="widgetaspectcheck" condition="widgetaspect=ThumbnailSmall">ThumbSmall</property>
        <property name="widgetaspectcheck" condition="widgetaspect=FanartSmall">FanSmall</property>
        <property name="widgetaspectcheck">Poster</property>
        <property name="widgetaspectsubcheck" condition="widgetaspect=SquareSmall">SqSmall</property>
        <property name="widgetaspectsubcheck" condition="widgetaspect=SquareMedium">SqMedium</property>
        <property name="widgetaspectsubcheck">Square</property>
        <property name="isbanner" condition="widgetaspectcheck=Banner">true</property>
        <property name="isbanner">false</property>
        <property name="isthumbnail" condition="widgetaspectcheck=Thumbnail">true</property>
        <property name="isthumbnail">false</property>
        <property name="isfanart" condition="widgetaspectcheck=Fanart">true</property>
        <property name="isfanart">false</property>
        <property name="isfanartsmall" condition="widgetaspectcheck=FanSmall">true</property>
        <property name="isfanartsmall">false</property>
        <property name="isthumbnailsmall" condition="widgetaspectcheck=ThumbSmall">true</property>
        <property name="isthumbnailsmall">false</property>
        <property name="isthumbnailpostersmall" condition="widgetaspectcheck=ThumbPoSmall">true</property>
        <property name="isthumbnailpostersmall">false</property>
        <property name="issquare" condition="widgetaspectcheck=Square">true</property>
        <property name="issquare">false</property>
        <property name="issquaremedium" condition="widgetaspectsubcheck=SqMedium">true</property>
        <property name="issquaremedium">false</property>
        <property name="issquaresmall" condition="widgetaspectsubcheck=SqSmall">true</property>
        <property name="issquaresmall">false</property>

        <controls>
            <control type="group" id="$PROPERTY[cid]000">
                <skinshortcuts>visibility</skinshortcuts>
                <visible>Integer.IsGreater(Container($PROPERTY[cid]).NumItems,0) | Container($PROPERTY[cid]).IsUpdating</visible>
                <control type="grouplist">
                    <include content="widget.title.label" condition="!Skin.HasSetting(hidewidgettitle)">
                        <param name="focusid" value="$PROPERTY[cid]"/>
                        <param name="idshort" value="$PROPERTY[slot]"/>
                        <param name="animation_condition" value="!Control.HasFocus($PROPERTY[cid])" />
                    </include>
                </control>
            </control>
            <control type="$PROPERTY[widgetlisttype]" id="$PROPERTY[cid]">
                <skinshortcuts>visibility</skinshortcuts>
                <visible>Integer.IsGreater(Container($PROPERTY[cid]).NumItems,0) | Container($PROPERTY[cid]).IsUpdating | String.IsEqual(Container(300).ListItem.Property(widget$PROPERTY[suffix]),custom)</visible>
                <visible condition="!suffix">Integer.IsGreater(Container($PROPERTY[cid]).NumItems,0) | Container($PROPERTY[cid]).IsUpdating | String.IsEqual(Container(300).ListItem.Property(widget),custom) | String.IsEqual(Container(300).ListItem.Property(widget),mysubmenu) | String.Contains(Container(300).ListItem.Property(widget),weather)</visible>
                <onclick condition="isgto=true">RunPlugin(plugin://script.service.gto?action=info&amp;item=$INFO[ListItem.Property(Item)])</onclick>
                <include content="DefMultiWidgetContainer">
                    <param name="id" value="$PROPERTY[cid]"/>
                    <param name="backid" value="301$PROPERTY[index]1"/>
                    <param name="height" value="$PROPERTY[layoutheight]"/>
                    <param name="height2" value="$PROPERTY[layoutheight2]"/>
                    <param name="idshort" value="$PROPERTY[index]"/>
                    <param name="AutoTime" value="$PROPERTY[widgetauto]"/>
                    <param name="orientation" value="$PROPERTY[orientation]"/>
                    <param name="AutoScrollCondition" value="!Control.HasFocus($PROPERTY[cid]) + !String.IsEmpty(Container(300).ListItem.Property(widgetAuto$PROPERTY[suffix])) + !String.IsEqual(Container(300).ListItem.Property(widgetListType),list) + System.IdleTime(1)"/>
                    <param name="animation_condition" value="!Control.HasFocus($PROPERTY[cid])" />
                </include>
                <!-- ItemLayouts -->
                <include content="TemplateNormalItemLayout" condition="isnormallayout=true">
                    <param name="shortcutsclearlogo" value="$PROPERTY[widgetclearlogothumb]"/>
                    <param name="aspectratio" value="$PROPERTY[aspectratio]"/>
                    <param name="distance" value="$PROPERTY[distance]"/>
                    <param name="Banner" value="$PROPERTY[isbanner]"/>
                    <param name="Thumbnail" value="$PROPERTY[isthumbnail]"/>
                    <param name="Fanart" value="$PROPERTY[isfanart]"/>
                    <param name="FanartSmall" value="$PROPERTY[isfanartsmall]"/>
                    <param name="ThumbnailSmall" value="$PROPERTY[isthumbnailsmall]"/>
                    <param name="ThumbnailPosterSmall" value="$PROPERTY[isthumbnailpostersmall]"/>
                    <param name="Square" value="$PROPERTY[issquare]"/>
                </include>
                <include condition="ispvrlayout=true">TemplatePvrItemLayout</include>
                <include content="TemplateWeatherItemLayout" condition="isweatherlayout=true">
                    <param name="Fanart" value="$PROPERTY[isfanart]"/>
                    <param name="Square" value="$PROPERTY[issquare]"/>
                </include>
                <include condition="issystemlayout=true">TemplateSystemItemLayout</include>
                <include content="TemplateSubmenuItemLayout" condition="issubmenulayout=true">
                    <param name="shortcutsid" value="$PROPERTY[cid]"/>
                    <param name="shortcutsclearlogo" value="$PROPERTY[widgetclearlogothumb]"/>
                    <param name="aspectratio" value="$PROPERTY[aspectratio]"/>
                    <param name="distance" value="$PROPERTY[distance]"/>
                    <param name="SquareMedium" value="$PROPERTY[issquaremedium]"/>
                    <param name="SquareSmall" value="$PROPERTY[issquaresmall]"/>
                </include>
                <!-- FocusLayouts -->
                <include content="TemplateNormalFocusLayout" condition="isnormallayout=true">
                    <param name="shortcutsid" value="$PROPERTY[cid]"/>
                    <param name="shortcutsclearlogo" value="$PROPERTY[widgetclearlogothumb]"/>
                    <param name="aspectratio" value="$PROPERTY[aspectratio]"/>
                    <param name="distance" value="$PROPERTY[distance]"/>
                    <param name="Banner" value="$PROPERTY[isbanner]"/>
                    <param name="Thumbnail" value="$PROPERTY[isthumbnail]"/>
                    <param name="Fanart" value="$PROPERTY[isfanart]"/>
                    <param name="FanartSmall" value="$PROPERTY[isfanartsmall]"/>
                    <param name="ThumbnailSmall" value="$PROPERTY[isthumbnailsmall]"/>
                    <param name="ThumbnailPosterSmall" value="$PROPERTY[isthumbnailpostersmall]"/>
                    <param name="Square" value="$PROPERTY[issquare]"/>
                </include>
                <include content="TemplatePvrFocusLayout" condition="ispvrlayout=true">
                    <param name="shortcutsid" value="$PROPERTY[cid]"/>
                </include>
                <include content="TemplateWeatherFocusLayout" condition="isweatherlayout=true">
                    <param name="shortcutsid" value="$PROPERTY[cid]"/>
                    <param name="Fanart" value="$PROPERTY[isfanart]"/>
                    <param name="Square" value="$PROPERTY[issquare]"/>
                </include>
                <include content="TemplateSystemFocusLayout" condition="issystemlayout=true">
                    <param name="shortcutsid" value="$PROPERTY[cid]"/>
                </include>
                <include content="TemplateSubmenuFocusLayout" condition="issubmenulayout=true">
                    <param name="shortcutsid" value="$PROPERTY[cid]"/>
                    <param name="shortcutsclearlogo" value="$PROPERTY[widgetclearlogothumb]"/>
                    <param name="aspectratio" value="$PROPERTY[aspectratio]"/>
                    <param name="distance" value="$PROPERTY[distance]"/>
                    <param name="SquareMedium" value="$PROPERTY[issquaremedium]"/>
                    <param name="SquareSmall" value="$PROPERTY[issquaresmall]"/>
                </include>
                <content limit="$PROPERTY[widgetlimit]" target="$PROPERTY[target]" sortby="$PROPERTY[widgetSortby]" sortorder="$PROPERTY[widgetSort]" browse="$VAR[DefBrowse]">$PROPERTY[content]</content>
            </control>
            <!-- InfoSub -->
            <control type="group" id="$PROPERTY[cid]100">
                <skinshortcuts>visibility</skinshortcuts>
                <visible>[Integer.IsGreater(Container($PROPERTY[cid]).NumItems,0) | Container($PROPERTY[cid]).IsUpdating] + [[ String.IsEqual($PROPERTY[isfullscreenwidget],true) | [Skin.HasSetting(homemenu.netflix) + Integer.IsGreater(Container($PROPERTY[cid]).NumItems,0)]] | [ !$EXP[Widget2Enabled] + !$EXP[Widget3Enabled] + !$EXP[Widget4Enabled] + !$EXP[Widget5Enabled] + !$EXP[Widget6Enabled] ]]</visible>
                <include content="Animation.FadeOutHomeFullscreenWidget">
                    <param name="condition" value="!Control.HasFocus($PROPERTY[cid])"/>
                </include>
                <control type="grouplist">
                    <include content="FullScreenInfoSub" condition="isnormallayout=true | ispvrlayout=true">
                        <param name="id" value="$PROPERTY[cid]"/>
                        <param name="labelisvisible" value="$PROPERTY[labelisvisible]"/>
                    </include>
                </control>
                <control type="grouplist">
                    <include condition="isweatherlayout=true">InfoSubWidgetWeather</include>
                </control>
                <control type="grouplist">
                    <include condition="issystemlayout=true" content="InfoSubWidgetSystem">
                        <param name="issettingslayout" value="$PROPERTY[issettingslayout]"/>
                        <param name="id" value="$PROPERTY[cid]"/>
                    </include>
                </control>
                <control type="grouplist">
                    <include content="ClearArtInfoSub" condition="isnormallayout=true">
                        <param name="id" value="$PROPERTY[cid]"/>
                    </include>
                </control>
            </control>
        </controls>
    </template>

    <!-- ============================================================
         Fixedlist single-widget layout (classic/vertical home menus)
         ============================================================ -->
    <template include="widget-vertical">
        <property name="content" condition="widgetPath">$PROPERTY[widgetPath]</property>
        <property name="content">$VAR[DefWidgetContent]</property>
